# ============================================================
# .env.railway.example — Variables de Entorno para Railway
# ============================================================
# Copia las variables de este archivo en el panel de cada
# servicio en Railway → Settings → Variables
# ============================================================

# ────────────────────────────────────────────
# SERVICIO: frontend (Next.js)
# ────────────────────────────────────────────
# Pegar en: Railway → frontend service → Variables

NEXT_PUBLIC_API_URL=https://api-gateway-production.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=TU_GOOGLE_MAPS_KEY

# ────────────────────────────────────────────
# SERVICIO: auth-service
# ────────────────────────────────────────────
# Pegar en: Railway → auth-service → Variables
# Nota: Los valores de Postgres y Redis los provee Railway automáticamente
# usando la sintaxis ${{NombrePlugin.VARIABLE}}

SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}
SPRING_DATA_REDIS_HOST=${{Redis.REDIS_HOST}}
SPRING_DATA_REDIS_PORT=${{Redis.REDIS_PORT}}
JWT_SECRET=genera-un-secret-largo-y-aleatorio-aqui-min-64-chars
SERVER_PORT=8081

# ────────────────────────────────────────────
# SERVICIO: profile-service
# ────────────────────────────────────────────

SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}
SPRING_DATA_REDIS_HOST=${{Redis.REDIS_HOST}}
SPRING_DATA_REDIS_PORT=${{Redis.REDIS_PORT}}
JWT_SECRET=genera-un-secret-largo-y-aleatorio-aqui-min-64-chars
SERVER_PORT=8082

# ────────────────────────────────────────────
# SERVICIO: jobs-service
# ────────────────────────────────────────────

SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}
SPRING_DATA_REDIS_HOST=${{Redis.REDIS_HOST}}
SPRING_DATA_REDIS_PORT=${{Redis.REDIS_PORT}}
JWT_SECRET=genera-un-secret-largo-y-aleatorio-aqui-min-64-chars
SERVER_PORT=8083

# ────────────────────────────────────────────
# SERVICIO: matching-service
# ────────────────────────────────────────────

SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}
SPRING_DATA_REDIS_HOST=${{Redis.REDIS_HOST}}
SPRING_DATA_REDIS_PORT=${{Redis.REDIS_PORT}}
JWT_SECRET=genera-un-secret-largo-y-aleatorio-aqui-min-64-chars
SERVER_PORT=8084

# ────────────────────────────────────────────
# SERVICIO: notification-service
# ────────────────────────────────────────────

REDIS_HOST=${{Redis.REDIS_HOST}}
REDIS_PORT=${{Redis.REDIS_PORT}}
JWT_SECRET=genera-un-secret-largo-y-aleatorio-aqui-min-64-chars
SERVER_PORT=8085

# ────────────────────────────────────────────
# SERVICIO: api-gateway
# ────────────────────────────────────────────

# URLs internas de Railway (sin dominio público, comunicación interna privada)
AUTH_SERVICE_URL=http://auth-service.railway.internal:8081
PROFILE_SERVICE_URL=http://profile-service.railway.internal:8082
JOBS_SERVICE_URL=http://jobs-service.railway.internal:8083
MATCHING_SERVICE_URL=http://matching-service.railway.internal:8084
NOTIFICATION_SERVICE_URL=http://notification-service.railway.internal:8085
JWT_SECRET=genera-un-secret-largo-y-aleatorio-aqui-min-64-chars
SERVER_PORT=8080

# ============================================================
# IMPORTANTE: Actualizar en Supabase Dashboard
# ============================================================
# Ir a: Authentication → URL Configuration
#
# Site URL:
#   https://catch-go-production.up.railway.app
#
# Redirect URLs (agregar):
#   https://catch-go-production.up.railway.app/auth/callback
#   https://catch-go-production.up.railway.app/auth/role-selection
# ============================================================
